import os

# Get API key from Hugging Face Secrets
api_key = os.getenv("OPENAI_API_KEY")

if not api_key:
    raise ValueError("OPENAI_API_KEY not found. Please add it in Hugging Face Secrets or .env file.")

# Initialize OpenAI client
from openai import OpenAI
client = OpenAI(api_key=api_key)


# Optional
LOCAL_IMAGE_NAME=ai-fitness-coach:latest
